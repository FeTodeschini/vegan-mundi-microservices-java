# Copy to terraform.tfvars.local and adjust values for your account.

aws_region       = "us-east-2"
environment      = "tools"

# Reuse existing VPC and a public subnet where Jenkins should live.
vpc_id           = "vpc-xxxxxxxxxxxxxxxxx"
public_subnet_id = "subnet-xxxxxxxxxxxxxxxxx"

instance_type      = "t3.micro"
key_name           = ""
root_volume_size   = 40
create_eip         = true
jenkins_port       = 8080

# Lock this down to your IP range in real usage.
allowed_ssh_cidrs     = ["076.98.179.193/32"]
allowed_jenkins_cidrs = ["76.98.179.193/32"]

# Optional bootstrap clone during first boot.
repo_url    = ""
repo_branch = "main"

jenkins_admin_id       = "admin"
jenkins_admin_password = "CHANGE_ME_STRONG_PASSWORD"
jenkins_pipeline_name  = "vegan-mundi-deploy"
jenkinsfile_path       = "jenkins/Jenkinsfile"

# Tighten permissions later as you harden the stack.
attach_policy_arns = [
  "arn:aws:iam::aws:policy/PowerUserAccess",
  "arn:aws:iam::aws:policy/IAMFullAccess",
  "arn:aws:iam::aws:policy/AmazonS3FullAccess"
]
